{
  "name": "scribd-dl",
  "version": "1.0.0",
  "description": "Scribd Document Downloader",
  "keywords": [],
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "ray.yukawai",
    "email": "ray.yukawai@gmail.com"
  },
  "type": "module",
  "main": "run.ts",
  "types": "module",
  "scripts": {
    "start": "bun run.ts",
    "tui": "bun tui.ts",
    "engine": "bun engine.ts",
    "app:dev": "cd app && bun run dev",
    "app:build": "cd app && bun run build",
    "app:test": "cd app && bun run test",
    "app:install": "cd app && bun install",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "lint": "oxlint run.ts tui.ts engine.ts src test",
    "lint:fix": "oxlint --fix run.ts tui.ts engine.ts src test",
    "format": "oxfmt --write package.json run.ts tui.ts engine.ts src test",
    "format:check": "oxfmt --check package.json run.ts tui.ts engine.ts src test"
  },
  "dependencies": {
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.96.1",
    "@effect/platform-bun": "^0.90.0",
    "cli-progress": "^3.12.0",
    "effect": "^3.21.3",
    "ink": "^7.0.5",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^25.1.0",
    "react": "^19.2.7",
    "sanitize-filename": "^1.6.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "packageManager": "bun@1.3.14"
}
