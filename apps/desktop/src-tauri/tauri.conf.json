{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "scribd-dl",
  "version": "0.0.0",
  "identifier": "dev.scribd-dl.desktop",
  "build": {
    "beforeDevCommand": "bun --filter @scribd-dl/desktop build:engine-binary && bun --filter @scribd-dl/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun --filter @scribd-dl/web build && bun --filter @scribd-dl/desktop build:engine-binaries",
    "frontendDist": "../../../apps/web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "scribd-dl",
        "width": 960,
        "height": 720,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:*; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:",
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/scribd-dl-engine"]
  },
  "plugins": {}
}
